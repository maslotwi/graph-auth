# Server
PORT=8080
BASE_URL=127.0.0.1:8080

# Public-facing URLs
ISSUER_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphauth

# Redis
REDIS_ADDR=localhost:6379

# SMTP (magic-link emails)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SERVER_NAME=localhost
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@graph-auth.local

# RSA private key for signing OIDC ID tokens (RS256)
# Generate with: openssl genrsa -out jwt_rsa_key.pem 2048
RSA_PRIVATE_KEY_PATH=./jwt_rsa_key.pem

# Allowed CORS origins (comma-separated). Defaults to http://localhost:5173
CORS_ORIGINS=http://localhost:5173
